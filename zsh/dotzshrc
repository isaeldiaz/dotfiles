export ZSH="$HOME/.oh-my-zsh"

export PATH=$HOME/bin:$HOME/.local/bin:$PATH

ZSH_THEME="crunch"

# Add wisely, as too many plugins slow down shell startup.
plugins=(git)

source $ZSH/oh-my-zsh.sh

export LANG=en_US.UTF-8

export EDITOR='nvim'

# Source local overrides (not committed to repo)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Modern CLI replacements
alias bat='batcat'

if command -v eza &> /dev/null; then
  alias ls='eza'
  alias ll='eza -l'
  alias la='eza -la'
  alias lt='eza --tree --level=2'
else
  alias ll='ls -l'
  alias la='ls -la'
fi

# Configure X11 for SSH sessions
if [ -n "$DISPLAY" ]; then
    # Set XAUTHORITY if not already set
    [ -z "$XAUTHORITY" ] && export XAUTHORITY=$HOME/.Xauthority

    # Import X11 variables to systemd user session
    systemctl --user import-environment DISPLAY XAUTHORITY 2>/dev/null || true
fi

# Clipboard via OSC 52 — works over SSH without X11 or tmux.
# WezTerm (and most modern terminals) receive the escape sequence and
# put the content directly into the host OS clipboard.
#
# Usage:
#   echo "hello" | clipipe      # pipe stdin to clipboard
#   clip "some text"            # copy arguments to clipboard
clip() {
  local encoded
  encoded=$(printf '%s' "$*" | base64 | tr -d '\n')
  printf "\033]52;c;%s\a" "$encoded"
}
clipipe() {
  local encoded
  encoded=$(base64 | tr -d '\n')
  printf "\033]52;c;%s\a" "$encoded"
}
